---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider" style="transform: translate3d(0,0,0);">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7] sm:aspect-[21/7] md:aspect-[24/7] bg-gray-950 overflow-hidden" id="slider-view-box" style="position: relative; display: block;">
    {demoSlides.map((slide, index) => (
      <div 
        class="custom-slider-item"
        style={`position: absolute; top: 0; left: 0; width: 100%; hieght: 100%; height: 100%; display: block; float: none; transform: none; pointer-events: ${index === 0 ? 'auto' : 'none'}; opacity: ${index === 0 ? '1' : '0'}; z-index: ${index === 0 ? '20' : '10'}; transition: none;`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full" title={slide.title}>
          <img
            src={slide.image}
            alt={slide.title}
            crossorigin="anonymous"
            loading={index === 0 ? "eager" : "lazy"}
            /* 100% MAXIMUM CLARITY WITHOUT ANY FILTERS */
            style="width: 100%; height: 100%; object-fit: cover; object-position: center; transition: none; display: block;"
            class="slider-img-target"
          />
          
          <div class="absolute bottom-3 left-4 z-30">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🔥 HARDCORE ANIMATION CANVAS LAYER */}
    <canvas id="particle-transition-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 25; display: none;"></canvas>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-40">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  let slideInterval: any;
  let animationFrameId: any;

  function initStrictParticleSlider() {
    if (slideInterval) clearInterval(slideInterval);
    if (animationFrameId) cancelAnimationFrame(animationFrameId);

    const slider = document.getElementById('astro-featured-slider');
    const slides = document.querySelectorAll('.custom-slider-item') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('.slider-dot');
    const canvas = document.getElementById('particle-transition-canvas') as HTMLCanvasElement;
    
    if (!slider || slides.length === 0 || dots.length === 0 || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000;
    let isAnimating = false;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // කැට ව්‍යුහය (Disintegration Particle)
    class PixelParticle {
      x: number;
      y: number;
      ox: number;
      oy: number;
      color: string;
      size: number;
      speedY: number;
      speedX: number;
      alpha: number;
      fade: number;

      constructor(x: number, y: number, color: string) {
        this.x = x;
        this.y = y;
        this.ox = x;
        this.oy = y;
        this.color = color;
        this.size = Math.random() * 3 + 1.5;
        this.speedY = -(Math.random() * 4 + 2); // යට සිට උඩට ගමන් කිරීම
        this.speedX = (Math.random() - 0.5) * 1.5;
        this.alpha = 1;
        this.fade = Math.random() * 0.015 + 0.01;
      }

      update() {
        this.y += this.speedY;
        this.x += this.speedX;
        this.alpha -= this.fade;
      }

      draw(context: CanvasRenderingContext2D) {
        context.save();
        context.globalAlpha = Math.max(0, this.alpha);
        context.fillStyle = this.color;
        context.fillRect(this.x, this.y, this.size, this.size);
        context.restore();
      }
    }

    function runStrictTransition(nextIndex: number) {
      if (isAnimating || nextIndex === currentIndex) return;
      isAnimating = true;

      const currentSlide = slides[currentIndex];
      const nextSlide = slides[nextIndex];
      const currentImg = currentSlide.querySelector('.slider-img-target') as HTMLImageElement;

      // 1. ඊළඟ පින්තූරය කිසිම හිස් තීරුවක් නැතුව යටින් ලෑස්ති කර තැබීම
      nextSlide.style.opacity = '1';
      nextSlide.style.zIndex = '15';
      nextSlide.style.pointerEvents = 'none';

      canvas.style.display = 'block';
      resizeCanvas();

      let particles: PixelParticle[] = [];
      const pCountX = 60; // තිරස්ව කැට ගණන
      const pCountY = 35; // සිරස්ව කැට ගණන
      
      // කැට සෑදීම (පින්තූරය දියවී යන ආකාරය පෙන්වීමට තැනින් තැනින් පික්සල් වර්ණ ලබා ගැනීම)
      for (let gY = 0; gY < pCountY; gY++) {
        for (let gX = 0; gX < pCountX; gX++) {
          const px = (canvas.width / pCountX) * gX + Math.random() * 5;
          const py = (canvas.height / pCountY) * gY + Math.random() * 5;
          // සයිට් එකේ ඩාර්ක් තේමාවට මැච් වෙන වර්ණ ත්‍රිත්වයක්
          const colors = ['#111827', '#1f2937', '#ff4500', '#3b82f6'];
          const randomColor = colors[Math.floor(Math.random() * colors.length)];
          particles.push(new PixelParticle(px, py, randomColor));
        }
      }

      let start: number | null = null;
      const duration = 1200; 

      function loop(timestamp: number) {
        if (!start) start = timestamp;
        const elapsed = timestamp - start;

        ctx!.clearRect(0, 0, canvas.width, canvas.height);

        // ⚡ [THE CRITICAL FIX]: පරණ පින්තූරය පැත්තකට නොගොස්, තැනින් තැන බොඳ වෙමින් දියවී යාම inline style මඟින්ම පාලනය කිරීම
        const progress = Math.min(1, elapsed / duration);
        currentSlide.style.opacity = (1 - progress).toString();
        currentSlide.style.filter = `blur(${progress * 15}px)`;

        // කැට අප්ඩේට් කර ඇඳීම
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.update();
          p.draw(ctx!);
          if (p.alpha <= 0 || p.y < 0) {
            particles.splice(i, 1);
          }
        }

        if (elapsed < duration || particles.length > 0) {
          animationFrameId = requestAnimationFrame(loop);
        } else {
          // ඇනිමේෂන් එක අවසන් වූ පසු ස්ටයිල්ස් නිවැරදිව ස්ථානගත කිරීම
          canvas.style.display = 'none';
          currentSlide.style.opacity = '0';
          currentSlide.style.zIndex = '10';
          currentSlide.style.filter = 'none';
          currentSlide.style.pointerEvents = 'none';

          nextSlide.style.zIndex = '20';
          nextSlide.style.pointerEvents = 'auto';

          dots.forEach((dot, i) => {
            if (i === nextIndex) {
              dot.classList.add('bg-primary', 'scale-125');
              dot.classList.remove('bg-white/50');
            } else {
              dot.classList.remove('bg-primary', 'scale-125');
              dot.classList.add('bg-white/50');
            }
          });

          currentIndex = nextIndex;
          isAnimating = false;
        }
      }

      animationFrameId = requestAnimationFrame(loop);
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        runStrictTransition(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        runStrictTransition(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  document.addEventListener('astro:page-load', initStrictParticleSlider);
  initStrictParticleSlider();
</script>
