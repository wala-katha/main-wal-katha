---

<div class="relative w-full overflow-hidden rounded-xl bg-gray-950 mb-8 shadow-lg select-none" id="astro-featured-slider">
  
  {/* SLIDER IMAGES CONTAINER */}
  <div class="relative w-full aspect-[16/7] sm:aspect-[21/7] md:aspect-[24/7] bg-gray-900 overflow-hidden" id="slider-view-box">
    {demoSlides.map((slide, index) => (
      <div 
        class="absolute inset-0 w-full h-full slide-item"
        style={`opacity: ${index === 0 ? '1' : '0'}; z-index: ${index === 0 ? '20' : '10'}; transition: opacity 1200ms ease-in-out, filter 1200ms ease-in-out;`}
        data-slide-index={index}
      >
        <a href={`/blog/${slide.id}/`} class="block w-full h-full group" title={slide.title}>
          {/* MAXIMUM CLARITY: පින්තූරය 100%ක් පිරිසිදුව, කිසිදු අඳුරු ලේයර් එකක් නොමැතිව මුල් පිටපත ලෙසම පෙන්වීම */}
          <Image
            src={slide.image}
            alt={slide.title}
            width={1200}
            height={525}
            quality="max"
            loading={index === 0 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "low"}
            decoding="async"
            class="w-full h-full object-cover object-center transition duration-700 group-hover:scale-[1.01]"
          />
          
          {/* ONLY CATEGORY TAG OVERLAY */}
          <div class="absolute bottom-3 left-4 z-20">
            <span class="bg-primary text-white px-2.5 py-1 text-[11px] sm:text-xs font-bold rounded uppercase tracking-wider shadow-md pointer-events-none">
              {humanize(slide.category)}
            </span>
          </div>
        </a>
      </div>
    ))}

    {/* 🧩 FINE PARTICLES CANVAS LAYER (zIndex 30 කරමින් පින්තූර වලට ඉහළින් කැට මතු වීම) */}
    <canvas id="particle-transition-canvas" class="absolute inset-0 pointer-events-none z-30 hidden w-full h-full"></canvas>
  </div>

  {/* NAVIGATION DOTS */}
  <div class="absolute bottom-3 right-4 flex gap-1.5 z-40">
    {demoSlides.map((_, index) => (
      <button
        class={`w-2 h-2 rounded-full transition-all duration-300 slider-dot ${index === 0 ? 'bg-primary scale-125' : 'bg-white/50'}`}
        data-index={index}
        aria-label={`Go to slide ${index + 1}`}
      ></button>
    ))}
  </div>
</div>

{/* SMOOTH PARTICLES & SEAMLESS BLUR TRANSITION SCRIPT */}
<script>
  function initFineParticleSlider() {
    const slider = document.getElementById('astro-featured-slider');
    const slides = document.querySelectorAll('.slide-item') as NodeListOf<HTMLElement>;
    const dots = document.querySelectorAll('.slider-dot');
    const canvas = document.getElementById('particle-transition-canvas') as HTMLCanvasElement;
    
    if (!slider || slides.length === 0 || dots.length === 0 || !canvas) return;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let currentIndex = 0;
    const totalSlides = slides.length;
    const intervalTime = 5000; // තත්පර 5න් 5ට ඔටෝ මාරු වීම
    let slideInterval: any;
    let isAnimating = false;

    function resizeCanvas() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    // ⚡ කැට (Particles) Logic එක
    class Particle {
      x: number;
      y: number;
      size: number;
      speedY: number;
      alpha: number;
      fadeSpeed: number;

      constructor(startX: number, startY: number) {
        this.x = startX;
        this.y = startY;
        this.size = Math.random() * 2 + 1; // පොඩි සියුම් කැට
        this.speedY = -(Math.random() * 2.5 + 1.5); // යට සිට උඩට ගමන් කරන වේගය
        this.alpha = 1;
        this.fadeSpeed = Math.random() * 0.015 + 0.008;
      }

      update() {
        this.y += this.speedY;
        this.alpha -= this.fadeSpeed;
      }

      draw(context: CanvasRenderingContext2D) {
        context.save();
        context.globalAlpha = Math.max(0, this.alpha);
        context.fillStyle = 'rgba(255, 255, 255, 0.75)'; // පින්තූර විසුරුවා හරින සුදු/ලා පැහැති කැට
        context.beginPath();
        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        context.fill();
        context.restore();
      }
    }

    let particles: Particle[] = [];

    function runParticleAnimation(onMidpoint: () => void) {
      canvas.classList.remove('hidden');
      particles = [];
      let animationFrameId: number;
      const startTime = Date.now();
      const duration = 1200; // සම්පූර්ණ ඇනිමේෂන් කාලය මිලි තත්පර 1200
      let triggered = false;

      function loop() {
        const elapsed = Date.now() - startTime;
        ctx!.clearRect(0, 0, canvas.width, canvas.height);

        // පල්ලෙහා සිට ක්‍රමයෙන් උඩට කැට මතු වීම (Bottom to Top Stream)
        if (elapsed < duration * 0.7) {
          // සෑම ෆ්‍රේම් එකකදීම යටම සීමාවෙන් අලුත් කැට ජනනය කිරීම
          for (let i = 0; i < 20; i++) {
            particles.push(new Particle(Math.random() * canvas.width, canvas.height - Math.random() * 20));
          }
        }

        particles.forEach((particle, index) => {
          particle.update();
          particle.draw(ctx!);
          if (particle.alpha <= 0 || particle.y < 0) {
            particles.splice(index, 1);
          }
        });

        // 🔄 SEAMLESS Crossover POINT: ඇනිමේෂන් එක මැදදී (මිලි තත්පර 400 දී) පින්තූර මාරු කිරීම සිදු කරයි
        if (elapsed >= 400 && !triggered) {
          triggered = true;
          onMidpoint();
        }

        if (elapsed < duration || particles.length > 0) {
          animationFrameId = requestAnimationFrame(loop);
        } else {
          canvas.classList.add('hidden');
          isAnimating = false;
        }
      }
      loop();
    }

    function transitionToSlide(nextIndex: number) {
      if (isAnimating || nextIndex === currentIndex) return;
      isAnimating = true;

      const currentSlide = slides[currentIndex];
      const nextSlide = slides[nextIndex];

      // 🛑 කලු පසුබිම සම්පූර්ණයෙන්ම වැසීමට Z-Index කළමනාකරණය:
      // පරණ පින්තූරය තවමත් උඩින්ම තබාගෙන (z-20) එය සෙමින් බොඳ කරමින් නැති කරයි
      currentSlide.style.zIndex = '20';
      currentSlide.style.filter = 'blur(15px)';
      currentSlide.style.opacity = '0';

      // ඊළඟ පින්තූරය කිසිදු බ්ලර් එකක් නැතුව යටින් සූදානම්ව තබයි (z-10)
      nextSlide.style.zIndex = '10';
      nextSlide.style.opacity = '1';
      nextSlide.style.filter = 'blur(0px)';

      runParticleAnimation(() => {
        // ඇනිමේෂන් එක මැදදී ඩොට්ස් ලස්සනට මාරු කිරීම
        dots.forEach((dot, i) => {
          if (i === nextIndex) {
            dot.classList.add('bg-primary', 'scale-125');
            dot.classList.remove('bg-white/50');
          } else {
            dot.classList.remove('bg-primary', 'scale-125');
            dot.classList.add('bg-white/50');
          }
        });

        // මාරු වීම අවසන් වූ පසු අලුත් පින්තූරය උඩ ලේයර් එකට (z-20) ගෙන එයි
        nextSlide.style.zIndex = '20';
        currentSlide.style.zIndex = '10';
        currentSlide.style.filter = 'blur(0px)'; // ඊළඟ වටයට සූදානම් කිරීම

        currentIndex = nextIndex;
      });
    }

    function startInterval() {
      slideInterval = setInterval(() => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        transitionToSlide(nextIndex);
      }, intervalTime);
    }

    function stopInterval() {
      clearInterval(slideInterval);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        if (isAnimating) return;
        stopInterval();
        const index = parseInt((e.target as HTMLElement).getAttribute('data-index') || '0');
        transitionToSlide(index);
        startInterval();
      });
    });

    slider.addEventListener('mouseenter', stopInterval);
    slider.addEventListener('mouseleave', startInterval);

    startInterval();
  }

  // Astro View Transitions සඳහා නූලටම සලස්වා ගැනීම
  document.addEventListener('astro:page-load', initFineParticleSlider);
  initFineParticleSlider();
</script>
