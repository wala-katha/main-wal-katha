---
const { section, currentPage, totalPages } = Astro.props;

const indexPageLink = currentPage === 2;
const hasPrevPage = currentPage > 1;
const hasNextPage = totalPages > currentPage;

let pageList = [];
for (let i = 1; i <= totalPages; i++) {
  pageList.push(i);
}
---

{
  totalPages > 1 && (
    <nav class="mb-4 flex justify-center space-x-2 text-center select-none" aria-label="Pagination">
      {/* ⬅️ PREVIOUS PAGE BUTTON */}
      {hasPrevPage ? (
        <a
          href={
            indexPageLink
              ? `${section ? "/" + section : "/"}`
              : `${section ? "/" + section : ""}/page/${currentPage - 1}/`
          }
          rel="prev"
          /* 🎯 UI FIX: බෝඩර්ස් white/20 කරලා, අකුරු/අයිකන පිරිසිදු සුදු (text-white) කළා. හොවර් එකේදී තීම් කලර් එක වන #01AD9F එකට මාරු වේ */
          class="border border-white/20 hover:border-[#01AD9F] hover:bg-[#01AD9F] text-white rounded-md h-10 w-10 leading-[36px] font-black flex items-center justify-center transition duration-200 shadow-sm"
        >
          <span class="sr-only">Previous</span>
          <svg
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
      ) : (
        /* Disabled අවස්ථාවලදී කළු පසුබිමට ගැළපෙන සේ මෘදු සුදු පැහැයකින් (text-white/20) පෙන්වීම */
        <span class="border border-white/10 opacity-30 rounded-md h-10 w-10 leading-[36px] font-black text-white flex items-center justify-center pointer-events-none">
          <span class="sr-only">Previous</span>
          <svg
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      )}

      {/* 🔢 PAGE INDEX NUMBERS */}
      {pageList.map((pagination, i) =>
        pagination === currentPage ? (
          /* 👑 ACTIVE PAGE HIGHLIGHT: දැනට ඉන්න පිටුව පෙන්වීමට සයිට් එකේ තීම් කලර් එක (#01AD9F) පසුබිමට දීලා, අකුරු තද කළු කළා */
          <span
            aria-current="page"
            class="bg-[#01AD9F] text-[#010203] rounded-md h-10 w-10 leading-[38px] font-black flex items-center justify-center shadow-md border border-[#01AD9F]"
          >
            {pagination}
          </span>
        ) : (
          /* INACTIVE PAGES: දැනට නැති පිටු වල අංක කළු පසුබිම මත පට්ට ලස්සනට පෙනෙන්න text-white සහ font-black කළා */
          <a
            href={
              i === 0
                ? `${section ? "/" + section : "/"}`
                : `${section ? "/" + section : ""}/page/${pagination}/`
            }
            class="border border-white/20 hover:border-[#01AD9F] hover:bg-[#01AD9F] hover:text-white text-white rounded-md h-10 w-10 leading-[36px] font-black flex items-center justify-center transition duration-200"
          >
            {pagination}
          </a>
        )
      )}

      {/* ➡️ NEXT PAGE BUTTON */}
      {hasNextPage ? (
        <a
          href={`${section ? "/" + section : ""}/page/${currentPage + 1}/`}
          rel="next"
          class="border border-white/20 hover:border-[#01AD9F] hover:bg-[#01AD9F] text-white rounded-md h-10 w-10 leading-[36px] font-black flex items-center justify-center transition duration-200 shadow-sm"
        >
          <span class="sr-only">Next</span>
          <svg
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
      ) : (
        <span class="border border-white/10 opacity-30 rounded-md h-10 w-10 leading-[36px] font-black text-white flex items-center justify-center pointer-events-none">
          <span class="sr-only">Next</span>
          <svg
            class="h-5 w-5"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
              clip-rule="evenodd"
            />
          </svg>
        </span>
      )}
    </nav>
  )
}
