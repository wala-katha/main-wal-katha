---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
};
const { posts } = Astro.props;
---

<div class="row gy-4 gx-2 sm:gx-4 justify-center">
  {
    posts.map((post) => (
      /* 🎯 UI & SEO GRID FIX: මොබයිල්, ටැබ්, ඩෙස්ක්ටොප් හැම එකකදීම එක පේළියට පෝස්ට් 3 බැගින් පේළි දෙකකට පෝස්ට් 6ක් හැඩගැස්වීම */
      <div class="col-4 flex flex-col justify-between group mb-4 text-center"> {/* ⚡ FIXED: මුළු කාඩ් එකම මැදට කිරීමට text-center යෙදුවා */}
        {post.data.image && (
          <a
            href={`/blog/${post.id}/`} /* ⚠️ FIXED: නිවැරදි Astro Content Layer URL එක දුන්නා */
            /* 👑 PREMIUM GOLDEN FRAME BAR: පින්තූරය වටා රන්වන් පැහැති සියුම් බෝඩර් එකක් සහ hover වීමේදී රන්වන් පැහැයෙන් බැබළෙන Shadow එකක් එක් කළා */
            class="rounded-lg block overflow-hidden group relative bg-gray-900 border-2 border-[#D4AF37]/60 hover:border-[#FFD700] transition-all duration-300 hover:shadow-[0_0_15px_rgba(212,175,55,0.5)]"
            style="aspect-ratio: 2 / 3;" /* ⚡ හෝම් පේජ් එකේ වගේම ලස්සන කෙළින් අතට 2:3 Ratio එක දුන්නා */
          >
            <Image
              class="group-hover:scale-[1.04] transition duration-300 w-full h-full object-contain"
              src={post.data.image}
              alt={post.data.title}
              width={500}
              height={750}
              loading="lazy"
              decoding="async"
            />
          </a>
        )}
        
        {/* INFO ROW: මැදට පෙළගස්වා මොබයිල් තිර වලට ගැළපෙන සේ මෙටා ඩේටා අකුරු ලස්සනට කුඩා කළා */}
        <ul class="mt-2 mb-1 flex flex-wrap items-center text-text text-[10px] sm:text-xs justify-center gap-x-2"> {/* ⚡ FIXED: justify-center මඟින් මැදට ගන්නා ලදී */}
          <li class="flex items-center flex-wrap">
            <BiCategoryAlt className="mr-0.5 h-3 w-3 sm:h-[14px] sm:w-[14px] text-gray-600" />
            <ul>
              {post.data.categories.slice(0, 1).map((category: string) => (
                <li class="inline-block">
                  <a
                    href={`/categories/${slugify(category)}/`}
                    class="hover:text-primary font-bold text-[9px] sm:text-xs bg-gray-100 dark:bg-darkmode-theme-light px-1 sm:px-2 py-0.5 rounded"
                  >
                    {humanize(category)}
                  </a>
                </li>
              ))}
            </ul>
          </li>
          <li class="hidden xs:flex items-center flex-wrap font-medium text-[9px] sm:text-xs text-gray-500">
            <BiCalendarEdit className="mr-0.5 h-3 w-3 sm:h-4 sm:w-4" />
            {dateFormat(post.data.date!)}
          </li>
        </ul>

        {/* POST TITLE: ⚡ FIXED: text-center සහ mx-auto මඟින් මාතෘකාවේ දෙවැනි පේළිය පවා හරි මැදටම සකස් කරන ලදී */}
        <h3 class="mb-1 line-clamp-2 leading-tight text-center mx-auto w-full">
          <a
            href={`/blog/${post.id}/`}
            class="block hover:text-primary transition duration-300 text-[11px] sm:text-base font-bold text-dark dark:text-darkmode-text text-center"
          >
            {post.data.title}
          </a>
        </h3>
      </div>
    ))
  }
</div>
