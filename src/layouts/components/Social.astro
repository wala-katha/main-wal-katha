---
const { source, className } = Astro.props;
import DynamicIcon from "@/helpers/DynamicIcon";

export interface ISocial {
  name: string;
  icon: string;
  link: string;
}

// React-icons major brands map with official brand colors
const iconMap: Record<string, { icon: string; color: string }> = {
  facebook: { icon: "FaFacebook", color: "#1877F2" },
  x: { icon: "FaXTwitter", color: "#F8F8FF" }, // X/Twitter is now white/black. On black BG, use white.
  instagram: { icon: "FaInstagram", color: "#E4405F" }, // Instagram gradient-like solid
  linkedin: { icon: "FaLinkedin", color: "#0077B5" },
  youtube: { icon: "FaYoutube", color: "#FF0000" },
  whatsapp: { icon: "FaWhatsapp", color: "#25D366" },
  telegram: { icon: "FaTelegram", color: "#26A5E4" },
  pinterest: { icon: "FaPinterest", color: "#BD081C" },
};

const normalize = (src: any): (ISocial & { color?: string })[] => {
  if (!src) return [];
  if (Array.isArray(src)) return src as (ISocial & { color?: string })[];
  if (typeof src === "object" && src !== null) {
    return Object.entries(src).map(([name, link]) => {
      const lowerName = String(name).toLowerCase();
      const mapped = iconMap[lowerName];
      return {
        name,
        link: String(link),
        icon: mapped?.icon || `Fa${String(name).charAt(0).toUpperCase()}${String(name).slice(1)}`,
        color: mapped?.color || "#F8F8FF", // Fallback to white on black
      };
    });
  }
  return [];
};

const items = normalize(source);
---

{/* 👑 PREMIUM SMART SOCIAL LINKS WRAPPER:
    කළු පසුබිම මත පට්ටම ලස්සනට වෙන් වෙලා පේනවා. select-none මගින් අකුරු තෝරා ගැනීම වැළැක්වීම. */}
<ul class={`flex flex-wrap items-center gap-3 select-none ${className}`}>
  {
    items.map((social: ISocial & { color?: string }) => (
      /* 🎯 UI HIGHLIGHT FIX: h-10 w-10 වටා සියුම් white/10 පසුබිමක් සහ white/20 සියුම් සුදු බෝඩරයක් සහිත රවුම් හැඩයක්.
         හොවර් එකේදී නිල වර්ණය (Glow Effect) පිටවන සේ හැදුවා. text-xl. */
      <li class="inline-block">
        <a
          aria-label={social.name}
          href={social.link}
          target="_blank"
          rel="noopener noreferrer nofollow"
          class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 border border-white/20 transition duration-300 hover:text-white hover:border-current hover:shadow-[0_0_15px_currentColor] text-xl"
          style={`color: ${social.color};`}
        >
          <span class="sr-only">{social.name}</span>
          <DynamicIcon className="inline-block" icon={social.icon} />
        </a>
      </li>
    ))
  }
</ul>
