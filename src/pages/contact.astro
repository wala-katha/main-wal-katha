---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import { BiSpreadsheet, BiEnvelope, BiPhoneCall, BiXCircle, BiCheckCircle } from "react-icons/bi";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;

if (!entry || !entry.data) {
  return Astro.redirect("/404");
}

const { address, email, phone } = config.contactinfo;
const { title, description, meta_title, image } = entry.data;

const base_url = (config?.site?.base_url || "").replace(/\/$/, ""); 
const canonicalUrl = `${base_url}/contact`;

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": title || "Contact Us",
  "description": description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න.",
  "url": canonicalUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": config?.site?.title || "Wala Katha",
    "url": base_url,
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": phone || "",
      "contactType": "customer service",
      "email": email || ""
    }
  }
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න."}
  image={image}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <section class="section">
    <div class="container">
      <h1 set:html={markdownify(title)} class="h2 page-heading" />
      <div class="row md:gx-5 gy-5">
        <div class="sm:col-5 md:col-4">
          <p class="mb-8 text-2xl font-bold text-text dark:text-slate-100">Contact Info</p>
          <ul class="flex flex-col space-y-8">
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiSpreadsheet className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Address</p>
              </div>
              <p set:html={markdownify(address)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiEnvelope className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Email</p>
              </div>
              <p set:html={markdownify(email)} class="mt-2 leading-5 pl-8 content text-text/80 dark:text-slate-300" />
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiPhoneCall className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Phone</p>
              </div>
              <p set:html={markdownify(phone)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
          </ul>
        </div>
        
        <div class="sm:col-7 md:col-8">
          {/* ⚡ SMART NOTICE BOX: පණිවිඩය සූදානම් වූ විට පෙන්වන කොටස */}
          <div id="form-success-alert" class="hidden mb-6 p-4 rounded-lg bg-emerald-500/20 border border-emerald-500 flex items-start text-emerald-400">
            <BiCheckCircle className="h-6 w-6 mr-3 flex-shrink-0 mt-0.5 text-emerald-400" />
            <div>
              <p class="font-bold text-lg text-emerald-400">පණිවිඩය සාර්ථකව සකස් වුණා!</p>
              <p class="text-sm opacity-90 mt-1 text-emerald-300">අප හා සම්බන්ධ වීම පිළිබඳව ස්තුතියි. ඔබගේ විමසීම ඊමේල් යෙදවුම හරහා දැන් විවෘත වේ.</p>
            </div>
          </div>

          {/* බාහිර API මත රඳා නොපවතින සෘජු ආකෘතිය */}
          <form
            id="smart-contact-form"
            class="contact-form row gy-3 justify-center"
          >
            {/* Name Input */}
            <div class="lg:col-6 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="name">
                Name <span class="text-red-600">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  id="form-name"
                  name="name"
                  type="text"
                  required
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Email Input */}
            <div class="lg:col-6 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="email">
                Email <span class="text-red-600">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  id="form-email"
                  name="email"
                  type="email"
                  required
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Subject Input */}
            <div class="col-12 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="subject">Subject</label>
              <div class="relative flex items-center">
                <input 
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400" 
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  id="form-subject"
                  name="subject" 
                  type="text" 
                />
                <button type="button" class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            {/* Message Input */}
            <div class="col-12 relative">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="message">
                Message <span class="text-red-600">*</span>
              </label>
              <div class="relative">
                <textarea 
                  class="form-textarea w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400" 
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  id="form-message"
                  name="message" 
                  rows="4" 
                  required
                ></textarea>
                <button type="button" class="clear-btn absolute right-3 top-3 text-gray-500 hover:text-red-500 hidden transition-all z-10">
                  <BiXCircle class="h-5 w-5" />
                </button>
              </div>
            </div>

            <div class="col-12">
              <button id="submit-btn" class="btn btn-primary mt-2 transition duration-300 hover:shadow-lg hover:shadow-primary/20 w-full sm:w-auto">
                Submit Now
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  {/* ⚡ SMART INPUT LOGIC & DIRECT EMAIL SENDING */}
  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("smart-contact-form");
      const successAlert = document.getElementById("form-success-alert");
      const submitBtn = document.getElementById("submit-btn");
      const formContainers = document.querySelectorAll(".relative");

      // 1. ❌ බටන් ක්‍රියාකාරීත්වය සහ වර්ණ සැකසුම්
      formContainers.forEach(container => {
        const input = container.querySelector(".form-input, .form-textarea");
        const clearBtn = container.querySelector(".clear-btn");

        if (!input || !clearBtn) return;

        input.style.color = "#000000";
        input.style.backgroundColor = "#ffffff";

        input.addEventListener("input", () => {
          if (input.value.length > 0) {
            clearBtn.classList.remove("hidden");
          } else {
            clearBtn.classList.add("hidden");
          }
        });

        clearBtn.addEventListener("click", (e) => {
          e.preventDefault();
          input.value = "";
          clearBtn.classList.add("hidden");
          input.focus();
        });
      });

      // 2. NATIVE SECURE DIRECT EMAIL HANDLING
      if (form) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = "Processing...";
          }

          const name = document.getElementById("form-name").value;
          const email = document.getElementById("form-email").value;
          const userSubject = document.getElementById("form-subject").value || "General Inquiry";
          const message = document.getElementById("form-message").value;

          // ඊමේල් එකෙහි අන්තර්ගතය පිළිවෙළකට සකස් කිරීම
          const targetEmail = "walkatha.com@gmail.com";
          const mailSubject = encodeURIComponent(`[WalaKatha Contact] ${userSubject}`);
          const mailBody = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\nMessage:\n${message}`);

          // බාහිර සේවා බිඳවැටීම් වලින් තොර සෘජු ලින්ක් එක
          const mailtoUrl = `mailto:${targetEmail}?subject=${mailSubject}&body=${mailBody}`;

          try {
            // පණිවිඩය සූදානම් බව පෙන්වා පද්ධතිය ක්‍රියාත්මක කිරීම
            if (successAlert) {
              successAlert.classList.remove("hidden");
              successAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            
            // පරිශීලකයාගේ නිල ඊමේල් මෘදුකාංගය විවෘත කිරීම
            window.location.href = mailtoUrl;
            
            form.reset();
            document.querySelectorAll(".clear-btn").forEach(btn => btn.classList.add("hidden"));
          } catch (error) {
            alert("Error preparing email connection.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = "Submit Now";
            }
          }
        });
      }
    });
  </script>
</Base>
