---
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { markdownify } from "@/lib/utils/textConverter";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";
import { BiSpreadsheet, BiEnvelope, BiPhoneCall } from "react-icons/bi";

const entry = (await getEntry(
  "contact",
  "-index"
)) as CollectionEntry<"contact">;

if (!entry || !entry.data) {
  return Astro.redirect("/404");
}

const { address, phone } = config.contactinfo;
const { title, description, meta_title, image } = entry.data;

const targetEmail = "walkatha.com@gmail.com";

const base_url = (config?.site?.base_url || "").replace(/\/$/, "");
const canonicalUrl = `${base_url}/contact`;

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": title || "Contact Us",
  "description": description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න.",
  "url": canonicalUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": config?.site?.title || "Wala Katha",
    "url": base_url,
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": phone || "",
      "contactType": "customer service",
      "email": targetEmail
    }
  }
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description || "අපේ වෙබ් අඩවිය සම්බන්ධ කර ගැනීමට අවශ්‍ය සියලුම තොරතුරු මෙතැනින් ලබා ගන්න."}
  image={image}
  canonical={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />

  <section class="section">
    <div class="container">
      <h1 set:html={markdownify(title)} class="h2 page-heading" />
      <div class="row md:gx-5 gy-5">
        <div class="sm:col-5 md:col-4">
          <p class="mb-8 text-2xl font-bold text-text dark:text-slate-100">Contact Info</p>
          <ul class="flex flex-col space-y-8">
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiSpreadsheet className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Address</p>
              </div>
              <p set:html={markdownify(address)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiEnvelope className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Email</p>
              </div>
              <p class="mt-2 leading-5 pl-8 content text-text/80 dark:text-slate-300">{targetEmail}</p>
            </li>
            <li>
              <div class="flex text-text dark:text-slate-100 items-center text-xl">
                <BiPhoneCall className="mr-2 text-primary h-6 w-6" />
                <p class="font-semibold">Phone</p>
              </div>
              <p set:html={markdownify(phone)} class="mt-2 leading-5 pl-8 text-text/80 dark:text-slate-300" />
            </li>
          </ul>
        </div>

        <div class="sm:col-7 md:col-8">
          <div
            id="form-success-alert"
            class="hidden mb-6 p-4 rounded-lg bg-emerald-500/20 border border-emerald-500"
            role="alert"
            aria-live="polite"
          >
            <div class="flex items-start text-emerald-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-bold text-lg text-emerald-400">පණිවිඩය සාර්ථකව ලැබුණා!</p>
                <p class="text-sm opacity-90 mt-1 text-emerald-300">
                  අප හා සම්බන්ධ වීම පිළිබඳව ස්තුතියි. ඔබගේ විමසීමට හැකි ඉක්මනින් පිළිතුරු සපයන්නෙමු.
                </p>
              </div>
            </div>
          </div>

          <div
            id="form-error-alert"
            class="hidden mb-6 p-4 rounded-lg bg-red-500/20 border border-red-500"
            role="alert"
            aria-live="polite"
          >
            <div class="flex items-start text-red-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-3 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="font-bold text-lg text-red-400">දෝෂයක් ඇතිවිය!</p>
                <p id="form-error-message" class="text-sm opacity-90 mt-1 text-red-300"></p>
              </div>
            </div>
          </div>

          <form
            id="smart-contact-form"
            class="contact-form row gy-3 justify-center"
            novalidate
          >
            <input type="hidden" name="access_key" value="cc7a3c5c-6eab-4676-a63d-06fe2f3f1559" />
            <input type="hidden" name="from_name" value="Wala Katha Contact Form" />
            <input type="hidden" name="redirect" value="false" />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

            <div class="lg:col-6 contact-field-wrap">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="name">
                නම <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  id="name"
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  name="name"
                  type="text"
                  placeholder="ඔබගේ නම"
                  required
                  autocomplete="name"
                />
                <button
                  type="button"
                  class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10"
                  aria-label="Clear name field"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </button>
              </div>
              <p class="field-error hidden mt-1 text-xs text-red-500">නම ඇතුළත් කරන්න.</p>
            </div>

            <div class="lg:col-6 contact-field-wrap">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="email">
                විද්‍යුත් තැපෑල <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <div class="relative flex items-center">
                <input
                  id="email"
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  name="email"
                  type="email"
                  placeholder="you@example.com"
                  required
                  autocomplete="email"
                />
                <button
                  type="button"
                  class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10"
                  aria-label="Clear email field"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </button>
              </div>
              <p class="field-error hidden mt-1 text-xs text-red-500">වලංගු විද්‍යුත් තැපැල් ලිපිනයක් ඇතුළත් කරන්න.</p>
            </div>

            <div class="col-12 contact-field-wrap">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="subject">
                විෂය
              </label>
              <div class="relative flex items-center">
                <input
                  id="subject"
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  name="subject"
                  type="text"
                  placeholder="ඔබගේ විමසීමේ විෂය"
                  autocomplete="off"
                />
                <button
                  type="button"
                  class="clear-btn absolute right-3 text-gray-500 hover:text-red-500 hidden transition-all z-10"
                  aria-label="Clear subject field"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </button>
              </div>
            </div>

            <div class="col-12 contact-field-wrap">
              <label class="mb-2 block text-text dark:text-slate-300 font-medium text-sm" for="message">
                පණිවිඩය <span class="text-red-500" aria-hidden="true">*</span>
              </label>
              <div class="relative">
                <textarea
                  id="message"
                  class="form-input w-full rounded-lg bg-white border border-border focus:border-primary focus:ring-1 focus:ring-primary pr-10 text-black placeholder-gray-400"
                  style="color: #000000 !important; font-weight: 700 !important; font-size: 16px !important; background-color: #ffffff !important;"
                  name="message"
                  rows="4"
                  placeholder="ඔබගේ පණිවිඩය මෙහි ලියන්න..."
                  required
                ></textarea>
                <button
                  type="button"
                  class="clear-btn absolute right-3 top-3 text-gray-500 hover:text-red-500 hidden transition-all z-10"
                  aria-label="Clear message field"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </button>
              </div>
              <p class="field-error hidden mt-1 text-xs text-red-500">පණිවිඩය ඇතුළත් කරන්න.</p>
            </div>

            <div class="col-12">
              <button
                id="submit-btn"
                type="submit"
                class="btn btn-primary mt-2 transition duration-300 hover:shadow-lg hover:shadow-primary/20 w-full sm:w-auto disabled:opacity-60 disabled:cursor-not-allowed"
              >
                <span id="submit-btn-text">Submit Now</span>
                <svg id="submit-spinner" xmlns="http://www.w3.org/2000/svg" class="hidden animate-spin h-4 w-4 ml-2 inline" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                </svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const form = document.getElementById("smart-contact-form");
      const successAlert = document.getElementById("form-success-alert");
      const errorAlert = document.getElementById("form-error-alert");
      const errorMessage = document.getElementById("form-error-message");
      const submitBtn = document.getElementById("submit-btn");
      const submitBtnText = document.getElementById("submit-btn-text");
      const submitSpinner = document.getElementById("submit-spinner");

      const fieldWraps = document.querySelectorAll(".contact-field-wrap");

      fieldWraps.forEach(wrap => {
        const input = wrap.querySelector(".form-input");
        const clearBtn = wrap.querySelector(".clear-btn");
        const fieldError = wrap.querySelector(".field-error");

        if (!input || !clearBtn) return;

        input.addEventListener("input", () => {
          clearBtn.classList.toggle("hidden", input.value.length === 0);
          if (fieldError) fieldError.classList.add("hidden");
          input.classList.remove("border-red-500");
        });

        clearBtn.addEventListener("click", (e) => {
          e.preventDefault();
          input.value = "";
          clearBtn.classList.add("hidden");
          input.focus();
        });
      });

      function hideAlerts() {
        successAlert.classList.add("hidden");
        errorAlert.classList.add("hidden");
      }

      function validateForm() {
        let valid = true;

        const nameInput = document.getElementById("name");
        const emailInput = document.getElementById("email");
        const messageInput = document.getElementById("message");

        const nameWrap = nameInput.closest(".contact-field-wrap");
        const nameError = nameWrap.querySelector(".field-error");
        if (!nameInput.value.trim()) {
          nameInput.classList.add("border-red-500");
          nameError.classList.remove("hidden");
          valid = false;
        }

        const emailWrap = emailInput.closest(".contact-field-wrap");
        const emailError = emailWrap.querySelector(".field-error");
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailInput.value.trim() || !emailRegex.test(emailInput.value.trim())) {
          emailInput.classList.add("border-red-500");
          emailError.classList.remove("hidden");
          valid = false;
        }

        const messageWrap = messageInput.closest(".contact-field-wrap");
        const messageError = messageWrap.querySelector(".field-error");
        if (!messageInput.value.trim()) {
          messageInput.classList.add("border-red-500");
          messageError.classList.remove("hidden");
          valid = false;
        }

        return valid;
      }

      if (form) {
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          hideAlerts();

          if (!validateForm()) return;

          submitBtn.disabled = true;
          submitBtnText.textContent = "යවමින්...";
          submitSpinner.classList.remove("hidden");

          const formData = new FormData(form);
          const object = {};
          formData.forEach((value, key) => { object[key] = value; });

          if (!object["subject"] || !object["subject"].trim()) {
            object["subject"] = "Wala Katha - නව සම්බන්ධතා පණිවිඩය";
          }

          object["replyto"] = object["email"];

          const json = JSON.stringify(object);

          try {
            const response = await fetch("https://api.web3forms.com/submit", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "Accept": "application/json"
              },
              body: json
            });

            const result = await response.json();

            if (response.ok && result.success) {
              successAlert.classList.remove("hidden");
              successAlert.scrollIntoView({ behavior: "smooth", block: "nearest" });
              form.reset();
              document.querySelectorAll(".clear-btn").forEach(btn => btn.classList.add("hidden"));
              document.querySelectorAll(".form-input").forEach(input => input.classList.remove("border-red-500"));
            } else {
              errorMessage.textContent = result.message || "කරුණාකර නැවත උත්සාහ කරන්න.";
              errorAlert.classList.remove("hidden");
              errorAlert.scrollIntoView({ behavior: "smooth", block: "nearest" });
            }
          } catch (error) {
            errorMessage.textContent = "ජාල සම්බන්ධතා දෝෂයක් ඇතිවිය. කරුණාකර අන්තර්ජාලය පරීක්ෂා කරන්න.";
            errorAlert.classList.remove("hidden");
            errorAlert.scrollIntoView({ behavior: "smooth", block: "nearest" });
          } finally {
            submitBtn.disabled = false;
            submitBtnText.textContent = "Submit Now";
            submitSpinner.classList.add("hidden");
          }
        });
      }
    });
  </script>
</Base>
