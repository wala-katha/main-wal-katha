---
import SearchBar from "@/helpers/SearchBar";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { BiSearchAlt } from "react-icons/bi";

// Retrieve all articles
const posts = await getSinglePage("posts");

// List of items to search in
const searchList = posts.map((item) => ({
  slug: item.id,
  data: item.data,
  content: item.body,
}));

// SEO අවශ්‍යතා සඳහා නිල ලින්ක් සහ ලෝගෝ එකතු කිරීම
const base_url = (config?.site?.base_url || "").replace(/\/$/, "");
const canonicalUrl = `${base_url}/search`;
const siteLogo = `${base_url}/images/logo.png`;

// 🚀 SEARCH PAGE SCHEMA 2026
const searchPageSchema = {
  "@context": "https://schema.org",
  "@type": "SearchResultsPage",
  "@id": `${canonicalUrl}/#searchpage`,
  "url": canonicalUrl,
  "name": "කතා සෙවීම | Search Sinhala Wal Katha Stories - WalaKatha",
  "description": "ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක් හෝ වැල කතාවක් නම හෝ අකුරු මඟින් පහසුවෙන් සොයා ගන්න.",
  "isPartOf": {
    "@type": "WebSite",
    "@id": `${base_url}/#website`,
    "url": base_url,
    "name": config?.site?.title || "Wala Katha"
  }
};
---

<Base 
  title="කතා සෙවීම | Search Sinhala Wal Katha & Wela Stories"
  meta_title="කතා සෙවීම | Search Sinhala Wal Katha & Wela Stories - WalaKatha"
  description="ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක්, වැල කතාවක් හෝ කෙටි කතාවක් නම භාවිත කරමින් ක්ෂණිකව සොයා ගන්න."
  canonical={canonicalUrl}
  image={siteLogo}
>
  {/* JSON-LD ව්‍යුහාත්මක දත්ත Google සෙවුම් යන්ත්‍ර සඳහා */}
  <script type="application/ld+json" set:html={JSON.stringify(searchPageSchema)} />

  {/* CORE SOCIAL META INJECTOR */}
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:title" content="කතා සෙවීම | Search Sinhala Wal Katha & Wela Stories" />
    <meta property="og:description" content="ඔබට අවශ්‍ය ඕනෑම සිංහල වල් කතාවක් නම භාවිත කරමින් ක්ෂණිකව සොයා ගන්න." />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={siteLogo} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
  </Fragment>

  {/* ⚡ PREMIUM ULTRA-DARK BACKGROUND & INTERACTIVE SEARCH CONTAINER */}
  <style is:inline>
    html, body {
      background-color: #050505 !important;
      color: #f8fafc !important;
    }

    /* 🧩 මිනිසුන්ගේ අවධානය කෙලින්ම ගන්නා Premium Search Wrapper Box */
    .search-hero-container {
      background: linear-gradient(135deg, #0d0d0d 0%, #080808 100%) !important;
      border: 1px solid #1a1a1a !important;
      border-radius: 20px !important;
      padding: 2.5rem 2rem !important;
      box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.7) !important;
      position: relative;
      overflow: visible !important; /* රිසල්ට්ස් බොක්ස් එක එළියට ඒමට ඉඩ දීම */
      margin-bottom: 2.5rem;
    }

    /* 🟢 පසුබිමෙන් මතුවන සියුම් Neon Emerald Glow එකක් */
    .search-hero-container::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.04) 0%, transparent 70%) !important;
      pointer-events: none;
    }

    /* 🎯 රිසල්ට්ස් කාඩ්ස් වලට බාධා නොකර Input එක පමණක් තෝරා ස්ටයිල් කිරීම (Conflict Resolved) */
    :global(.search-hero-container input[type="text"]), 
    :global(.search-hero-container .form-input),
    :global(#search-bar) {
      background-color: #121212 !important;
      border: 2px solid #262626 !important;
      color: #ffffff !important;
      font-size: 18px !important;
      font-weight: 600 !important;
      border-radius: 12px !important;
      padding: 0.85rem 1.2rem 0.85rem 1.2rem !important;
      width: 100% !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
      display: block !important;
    }

    /* Input එක උඩ ක්ලික් කළ විට එන ආකර්ෂණීය Glow එක */
    :global(.search-hero-container input[type="text"]:focus), 
    :global(#search-bar:focus) {
      border-color: #10b981 !important;
      box-shadow: 0 0 15px rgba(16, 185, 129, 0.25) !important;
      background-color: #161616 !important;
      outline: none !important;
    }

    /* 🧩 ටයිප් කිරීමෙන් පසු පහළින් මතුවන Search Results කාඩ්ස් කළු පසුබිමට ගැළපීම */
    :global(.search-result-item), :global(.search-hero-container .post-card), :global(.search-hero-container .card) {
      background-color: #0d0d0d !important;
      border: 1px solid #1a1a1a !important;
      border-radius: 14px !important;
      margin-top: 1rem !important;
      text-align: left !important;
    }
    
    :global(.search-result-item:hover) {
      border-color: rgba(16, 185, 129, 0.3) !important;
      background-color: #121212 !important;
    }

    /* 100% PENALTY-FREE HIDDEN H1 STYLE (Google Safe Pattern) */
    .invisible-seo-h1 {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }
  </style>

  {/* ප්‍රධාන සෙක්ෂන් එක */}
  <main class="section pt-6 pb-12 min-h-screen bg-[#050505] antialiased">
    <div class="container max-w-4xl">
      
      {/* 🎯 Google Search Bots සඳහා පමණක් පෙනෙන ආරක්ෂිත H1 ශීර්ෂකය */}
      <div class="invisible-seo-h1">
        <h1>සිංහල වල් කතා සෙවුම් පියස | Search Sinhala Wal Katha Stories</h1>
        <p>WalaKatha වෙබ් අඩවියේ ඇති සියලුම වැල කතා සහ කෙටි කතා මෙතැනින් සොයා ගන්න.</p>
      </div>

      {/* 🔥 ATTENTION-GRABBING HERO BOX */}
      <div class="search-hero-container text-center">
        <div class="flex justify-center items-center mb-3 text-emerald-400">
          <BiSearchAlt className="h-8 w-8 mr-2 animate-pulse" />
          <span class="text-xs md:text-sm font-bold tracking-widest uppercase text-emerald-400/80">WalaKatha Instant Finder</span>
        </div>
        <h2 class="text-xl md:text-2xl font-black text-white mb-2">ඔබට 😊 අවශ්‍ය ඕනෑම කතාවක් මෙතැනින් සොයන්න</h2>
        <p class="text-xs md:text-sm text-slate-400 mb-6 max-w-lg mx-auto">කතාවේ නම, ලේඛකයා හෝ ඔබට මතක ඕනෑම වචනයක් පහත පෙට්ටියේ Type කරන්න.</p>
        
        {/* React සෙවුම් සංරචකය */}
        <div class="text-left relative w-full">
          <SearchBar client:load searchList={searchList} />
        </div>
      </div>
      
    </div>
  </main>
</Base>
